{
  "name": "finance-ontology-mcp",
  "version": "1.0.0",
  "description": "Finance team ontology management system with MCP server for AI agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types src/index.ts",
    "seed": "node --experimental-strip-types src/seed/run-seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "uuid": "^11.1.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.jest.json",
          "diagnostics": {
            "ignoreCodes": [151002]
          }
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
